generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Enum Definitions (kept as String due to Turso/libSQL driver adapter) ──
// Validation should be enforced at the application/Zod layer.
// UserRole: user, runner, admin
// ListingStatus: active, sold, paused, removed
// ListingCondition: brand_new, like_new, fairly_used, old
// DeliveryOrderStatus: created, searching, runner_assigned, runner_en_route, picked_up, in_transit, delivered, completed, cancelled
// PaymentStatus: unpaid, escrow, released, refunded
// TaskStatus: open, matched, in_progress, completed, cancelled
// ReportReason: scam, fake_listing, harassment, spam, illegal_item

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  email              String   @unique
  avatar             String?
  faculty            String?
  department         String?
  level              String?
  bio                String?
  phone              String?
  whatsapp           String?
  hostel             String?
  verificationStatus String   @default("unverified") // unverified, email_verified, unilag_verified
  trustScore         Int      @default(0)
  ratingAverage      Float    @default(0)
  totalReviews       Int      @default(0)
  role               String   @default("user") // UserRole: user, runner, admin
  isRunner           Boolean  @default(false)
  runnerRating       Float    @default(0)
  tasksCompleted     Int      @default(0)
  runnerAvailabilityStatus String @default("offline") // offline, available, busy
  runnerLastActiveAt DateTime?
  runnerCurrentLat   Float?
  runnerCurrentLng   Float?
  runnerLocationUpdatedAt DateTime?
  clerkId            String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  listings            Listing[]
  sentMessages        Message[]
  chatsAsBuyer        Chat[]            @relation("BuyerChats")
  chatsAsSeller       Chat[]            @relation("SellerChats")
  savedListings       SavedListing[]
  reviewsGiven        Review[]          @relation("ReviewAuthor")
  reviewsReceived     Review[]          @relation("ReviewTarget")
  reportsMade         Report[]          @relation("ReportAuthor")
  notifications       Notification[]
  store               Store?
  storeFollows        StoreFollow[]
  pushSubscriptions   PushSubscription[]
  tasksCreated        Task[]            @relation("TaskCreator")
  taskApplications    TaskApplication[] @relation("RunnerApplications")
  runnerOffers        TaskOffer[]       @relation("RunnerOffers")
  customerOffers      TaskOffer[]       @relation("CustomerOffers")
  assignedTasks       Task[]            @relation("AssignedRunner")
  runnerProfile       RunnerProfile?
  deliveryOrders      DeliveryOrder[]   @relation("DeliveryCustomer")
  deliveryAssignments DeliveryOrder[]   @relation("DeliveryRunner")
  deliveryOffersMade  DeliveryOffer[]   @relation("DeliveryOfferRunner")
  sentDeliveryMessages DeliveryMessage[]
  wallet              RunnerWallet?
  payouts             PayoutRequest[]
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  storeId     String?
  title       String
  description String
  price       Float
  category    String
  condition   String?  // ListingCondition: brand_new, like_new, fairly_used, old
  negotiable  Boolean  @default(true)
  location    String?
  status      String   @default("active") // ListingStatus: active, sold, paused, removed
  views       Int      @default(0)
  likesCount  Int      @default(0)
  boosted     Boolean  @default(false)
  boostedUntil DateTime?
  images      String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller        User          @relation(fields: [sellerId], references: [id])
  store         Store?        @relation(fields: [storeId], references: [id])
  chatListings  Chat[]
  savedBy       SavedListing[]
  listingReports Report[]
  boosts        Boost[]

  @@index([category])
  @@index([status])
  @@index([sellerId])
  @@index([storeId])
}

model Chat {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())

  listing  Listing  @relation(fields: [listingId], references: [id])
  buyer    User     @relation("BuyerChats", fields: [buyerId], references: [id])
  seller   User     @relation("SellerChats", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId, sellerId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  message   String
  imageUrl  String?
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  sellerId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  seller   User @relation("ReviewTarget", fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([reviewerId])
  @@index([reviewerId, sellerId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  listingId  String?
  reason     String   // ReportReason: scam, fake_listing, harassment, spam, illegal_item
  status     String   @default("pending") // pending, reviewed, resolved, dismissed
  createdAt  DateTime @default(now())

  reporter User    @relation("ReportAuthor", fields: [reporterId], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])

  @@index([reporterId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // new_message, item_sold, boost_expiry, new_follower, task_accepted, system
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?  // JSON metadata for deep links
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Store / Shop Profile ──
model Store {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  slug        String   @unique
  category    String   // electronics, fashion, food, beauty, repair, laundry, printing, tutoring, photography, barbing, others
  description String?
  logo        String?  // compressed webp
  banner      String?  // compressed webp
  phone       String?
  whatsapp    String?
  instagram   String?
  twitter     String?
  address     String?  // campus location
  openHours   String?  // e.g. "Mon-Fri 9am-6pm"
  isVerified  Boolean  @default(false)
  followCount Int      @default(0)
  totalSales  Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User          @relation(fields: [ownerId], references: [id])
  listings  Listing[]
  followers StoreFollow[]

  @@index([category])
  @@index([slug])
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([storeId])
}

// ── Push Notifications ──
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String   // JSON: { p256dh, auth }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Boost {
  id               String   @id @default(cuid())
  listingId        String
  paymentReference String?
  flutterwaveTxRef String?
  amount           Float    @default(0)
  planId           String?  // basic, standard, premium, ultra
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  listingId       String?
  type            String   // boost, vendor_subscription, sponsored_ad
  amount          Float
  currency        String   @default("NGN")
  flutterwaveTxRef String  @unique
  flutterwaveId    String?
  status          String   @default("pending") // pending, successful, failed, refunded
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([listingId])
}

model Task {
  id               String   @id @default(cuid())
  creatorId        String
  assignedRunnerId String?
  title            String
  description      String
  reward           Float
  category         String
  location         String?
  pickupLocation   String?
  pickupLabel      String?
  dropoffLabel     String?
  pickupLat        Float?
  pickupLng        Float?
  dropoffLat       Float?
  dropoffLng       Float?
  serviceArea      String?  @default("unilag")
  negotiationStatus String @default("open") // open, negotiating, matched, closed
  urgency          String   @default("medium") // low, medium, high, urgent
  status           String   @default("open") // TaskStatus: open, matched, in_progress, completed, cancelled
  deadline         DateTime?
  images           String   @default("[]")
  estimatedDistanceMeters Int?
  estimatedDurationMinutes Int?
  matchedAt        DateTime?
  pickedUpAt       DateTime?
  deliveringAt     DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creator          User              @relation("TaskCreator", fields: [creatorId], references: [id])
  assignedRunner   User?             @relation("AssignedRunner", fields: [assignedRunnerId], references: [id])
  applications     TaskApplication[]
  offers           TaskOffer[]

  @@index([status])
  @@index([creatorId])
  @@index([category])
}

model TaskApplication {
  id            String   @id @default(cuid())
  taskId        String
  runnerId      String
  message       String?
  proposedPrice Float?   // Runner's counter-offer (InDrive style)
  status        String   @default("pending") // pending, accepted, rejected, countered, expired
  createdAt     DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id])
  runner User @relation("RunnerApplications", fields: [runnerId], references: [id])

  @@unique([taskId, runnerId])
  @@index([taskId])
  @@index([runnerId])
}

model TaskOffer {
  id            String   @id @default(cuid())
  taskId        String
  runnerId      String
  customerId    String
  amount        Float
  message       String?
  createdByRole String   // runner, customer
  status        String   @default("open") // open, accepted, rejected, expired, superseded
  createdAt     DateTime @default(now())

  task          Task     @relation(fields: [taskId], references: [id])
  runner        User     @relation("RunnerOffers", fields: [runnerId], references: [id])
  customer      User     @relation("CustomerOffers", fields: [customerId], references: [id])

  @@index([taskId, runnerId, createdAt])
  @@index([customerId])
  @@index([status])
}

model RunnerProfile {
  id                           String   @id @default(cuid())
  userId                       String   @unique
  status                       String   @default("pending") // pending, approved, rejected
  transportMode                String
  availabilityText             String
  preferredZone                String?
  deliveryExperience           String?
  motivation                   String?
  studentId                    String
  profilePhoto                 String
  studentIdImage               String
  emergencyContactName         String
  emergencyContactPhone        String
  emergencyContactRelationship String?
  reviewedAt                   DateTime?
  reviewedBy                   String?
  reviewNote                   String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  user                         User     @relation(fields: [userId], references: [id])

  @@index([status])
}

// ════════════════════════════════════════════════════════════════
// ── Real-Time Delivery System (Uber/inDrive Model) ──
// ════════════════════════════════════════════════════════════════

model DeliveryOrder {
  id               String   @id @default(cuid())
  customerId       String
  assignedRunnerId String?
  status           String   @default("created") // DeliveryOrderStatus: created, searching, runner_assigned, runner_en_route, picked_up, in_transit, delivered, completed, cancelled
  pickupLat        Float
  pickupLng        Float
  pickupAddress    String
  dropoffLat       Float
  dropoffLng       Float
  dropoffAddress   String
  serviceArea      String   @default("unilag")
  estimatedDistanceMeters  Int?
  estimatedDurationMinutes Int?
  customerPrice     Float
  finalPrice        Float?
  surgeMultiplier   Float    @default(1.0)
  platformCommission Float   @default(0)
  cancellationFee   Float    @default(0)
  pickupCode        String
  category          String   @default("other")
  urgency           String   @default("standard")
  title             String
  description       String
  itemImages        String   @default("[]")
  itemCost           Float?
  itemPaymentMethod  String?
  deliveryType       String   @default("marketplace")
  dropoffCode        String?
  pickupPhotoUrl     String?
  dropoffPhotoUrl    String?
  preferredRunnerGender String?    // 'male' | 'female' | 'any'
  safeMeetupPoint       String?    // 'hostel_lobby' | 'faculty_entrance' | 'gate' | null
  quickAccept        Boolean  @default(false)
  cancelReason      String?
  cancelledBy       String?
  customerRating    Int?
  runnerRating      Int?
  customerReview    String?
  runnerReview      String?
  // ── Escrow Payment Fields ──
  paymentStatus     String   @default("unpaid") // PaymentStatus: unpaid, escrow, released, refunded
  paymentMethod     String?  // flutterwave, wallet
  paymentReference  String?  // Flutterwave tx_ref or internal ref
  flutterwaveTransactionId  String?    // Flutterwave's numeric transaction ID for refunds
  customerPaidAt    DateTime?
  escrowReleasedAt  DateTime?
  refundReason      String?
  refundProcessedAt DateTime?
  // ── Timestamps ──
  searchingAt       DateTime?
  assignedAt        DateTime?
  enRouteAt         DateTime?
  pickedUpAt        DateTime?
  inTransitAt       DateTime?
  deliveredAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          User              @relation("DeliveryCustomer", fields: [customerId], references: [id])
  assignedRunner    User?             @relation("DeliveryRunner", fields: [assignedRunnerId], references: [id])
  offers            DeliveryOffer[]
  statusLogs        OrderStatusLog[]
  deliveryMessages  DeliveryMessage[]

  @@index([status])
  @@index([customerId])
  @@index([assignedRunnerId])
  @@index([category])
  @@index([serviceArea])
  @@index([createdAt])
}

model DeliveryOffer {
  id                        String   @id @default(cuid())
  orderId                   String
  runnerId                  String
  runnerPrice               Float
  estimatedArrivalMinutes   Int?
  message                   String?
  status                    String   @default("open")
  expiresAt                 DateTime
  createdAt                 DateTime @default(now())

  order   DeliveryOrder @relation(fields: [orderId], references: [id])
  runner  User          @relation("DeliveryOfferRunner", fields: [runnerId], references: [id])

  @@unique([orderId, runnerId])
  @@index([orderId])
  @@index([runnerId])
  @@index([status])
  @@index([expiresAt])
}

model DeliveryMessage {
  id        String   @id @default(cuid())
  orderId   String
  senderId  String
  message   String
  type      String   @default("text")
  createdAt DateTime @default(now())

  order     DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])

  @@index([orderId, createdAt])
}

model OrderStatusLog {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  timestamp  DateTime @default(now())
  metadata   String?

  order DeliveryOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([timestamp])
}

// ════════════════════════════════════════════════════════════════
// ── Runner Wallet & Payout System ──
// ════════════════════════════════════════════════════════════════

model RunnerWallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  balance         Float    @default(0)     // Available balance (can withdraw)
  pendingBalance  Float    @default(0)     // In escrow (being held for active deliveries)
  totalEarned     Float    @default(0)     // Lifetime earnings
  totalWithdrawn  Float    @default(0)     // Lifetime withdrawals
  totalHeld       Float    @default(0)     // Total platform commission collected
  lastPayoutAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id])
  transactions  WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String   // credit, debit, escrow_hold, escrow_release, payout, refund, commission
  amount      Float
  balance     Float    // Balance after transaction
  reference   String?  // DeliveryOrder ID or PayoutRequest ID
  description String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  wallet RunnerWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model PayoutRequest {
  id              String   @id @default(cuid())
  runnerId        String
  amount          Float
  fee             Float    @default(0)     // Payout processing fee
  netAmount       Float                     // amount - fee
  status          String   @default("pending") // pending, processing, completed, failed, cancelled
  method          String   @default("bank_transfer") // bank_transfer, mobile_money
  bankName        String?
  bankCode        String?     // Flutterwave bank code (e.g. '044' for Access Bank)
  accountNumber   String?
  accountName     String?
  flutterwaveTxRef String?
  processedAt     DateTime?
  failedReason    String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  runner User @relation(fields: [runnerId], references: [id])

  @@index([runnerId])
  @@index([status])
  @@index([createdAt])
}

// ════════════════════════════════════════════════════════════════
// ── Enterprise Audit Logging ──
// ════════════════════════════════════════════════════════════════

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // The action performed (e.g., 'payment.initiated')
  actorId      String   // User who performed the action
  actorRole    String   // Role at time of action
  resourceType String   // Type of resource (e.g., 'delivery', 'payment', 'user')
  resourceId   String   // ID of the affected resource
  description  String   // Human-readable description
  metadata     String?  // JSON with additional context
  ipAddress    String?  // Client IP address
  userAgent    String?  // Client user agent
  createdAt    DateTime @default(now())

  // Indexes for common queries
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt])
}
