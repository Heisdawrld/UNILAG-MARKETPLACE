generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  email              String   @unique
  avatar             String?
  faculty            String?
  department         String?
  level              String?
  bio                String?
  phone              String?
  whatsapp           String?
  hostel             String?
  verificationStatus String   @default("unverified") // unverified, email_verified, unilag_verified
  trustScore         Int      @default(0)
  ratingAverage      Float    @default(0)
  totalReviews       Int      @default(0)
  role               String   @default("user") // user, seller, vendor, admin
  isRunner           Boolean  @default(false)
  runnerRating       Float    @default(0)
  tasksCompleted     Int      @default(0)
  clerkId            String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  listings            Listing[]
  sentMessages        Message[]
  chatsAsBuyer        Chat[]            @relation("BuyerChats")
  chatsAsSeller       Chat[]            @relation("SellerChats")
  savedListings       SavedListing[]
  reviewsGiven        Review[]          @relation("ReviewAuthor")
  reviewsReceived     Review[]          @relation("ReviewTarget")
  reportsMade         Report[]          @relation("ReportAuthor")
  notifications       Notification[]
  store               Store?
  storeFollows        StoreFollow[]
  pushSubscriptions   PushSubscription[]
  tasksCreated        Task[]            @relation("TaskCreator")
  taskApplications    TaskApplication[] @relation("RunnerApplications")
  assignedTasks       Task[]            @relation("AssignedRunner")
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  storeId     String?
  title       String
  description String
  price       Float
  category    String
  condition   String   // brand_new, like_new, fairly_used, old
  negotiable  Boolean  @default(true)
  location    String?
  status      String   @default("active") // active, sold, paused, removed
  views       Int      @default(0)
  likesCount  Int      @default(0)
  boosted     Boolean  @default(false)
  boostedUntil DateTime?
  images      String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller        User          @relation(fields: [sellerId], references: [id])
  store         Store?        @relation(fields: [storeId], references: [id])
  chatListings  Chat[]
  savedBy       SavedListing[]
  listingReports Report[]

  @@index([category])
  @@index([status])
  @@index([sellerId])
  @@index([storeId])
}

model Chat {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())

  listing  Listing  @relation(fields: [listingId], references: [id])
  buyer    User     @relation("BuyerChats", fields: [buyerId], references: [id])
  seller   User     @relation("SellerChats", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId, sellerId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  message   String
  imageUrl  String?
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  sellerId   String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  reviewer User @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  seller   User @relation("ReviewTarget", fields: [sellerId], references: [id])

  @@index([sellerId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  listingId  String?
  reason     String   // scam, fake_listing, harassment, spam, illegal_item
  status     String   @default("pending") // pending, reviewed, resolved, dismissed
  createdAt  DateTime @default(now())

  reporter User    @relation("ReportAuthor", fields: [reporterId], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // new_message, item_sold, boost_expiry, new_follower, task_accepted, system
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?  // JSON metadata for deep links
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Store / Shop Profile ──
model Store {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  slug        String   @unique
  category    String   // electronics, fashion, food, beauty, repair, laundry, printing, tutoring, photography, barbing, others
  description String?
  logo        String?  // compressed webp
  banner      String?  // compressed webp
  phone       String?
  whatsapp    String?
  instagram   String?
  twitter     String?
  address     String?  // campus location
  openHours   String?  // e.g. "Mon-Fri 9am-6pm"
  isVerified  Boolean  @default(false)
  followCount Int      @default(0)
  totalSales  Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User          @relation(fields: [ownerId], references: [id])
  listings  Listing[]
  followers StoreFollow[]

  @@index([category])
  @@index([slug])
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([storeId])
}

// ── Push Notifications ──
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String   // JSON: { p256dh, auth }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Boost {
  id               String   @id @default(cuid())
  listingId        String
  paymentReference String?
  flutterwaveTxRef String?
  amount           Float    @default(0)
  planId           String?  // basic, standard, premium, ultra
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([listingId])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  listingId       String?
  type            String   // boost, vendor_subscription, sponsored_ad
  amount          Float
  currency        String   @default("NGN")
  flutterwaveTxRef String  @unique
  flutterwaveId    String?
  status          String   @default("pending") // pending, successful, failed, refunded
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Task {
  id               String   @id @default(cuid())
  creatorId        String
  assignedRunnerId String?
  title            String
  description      String
  reward           Float
  category         String
  location         String?
  pickupLocation   String?
  urgency          String   @default("medium") // low, medium, high, urgent
  status           String   @default("open") // open, assigned, in_progress, completed, cancelled
  deadline         DateTime?
  images           String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creator          User              @relation("TaskCreator", fields: [creatorId], references: [id])
  assignedRunner   User?             @relation("AssignedRunner", fields: [assignedRunnerId], references: [id])
  applications     TaskApplication[]

  @@index([status])
  @@index([creatorId])
  @@index([category])
}

model TaskApplication {
  id            String   @id @default(cuid())
  taskId        String
  runnerId      String
  message       String?
  proposedPrice Float?   // Runner's counter-offer (InDrive style)
  status        String   @default("pending") // pending, accepted, rejected, countered, expired
  createdAt     DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id])
  runner User @relation("RunnerApplications", fields: [runnerId], references: [id])

  @@unique([taskId, runnerId])
  @@index([taskId])
  @@index([runnerId])
}
