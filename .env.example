# ==========================================
# UNILAG Marketplace - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values

# ── Database (REQUIRED for the app to work) ──
# Turso is used for production. Get your credentials at https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# DATABASE_URL must be set to the same value as TURSO_DATABASE_URL in production.
# For local development, use a local SQLite file:
DATABASE_URL=file:./dev.db

# ── Clerk Authentication (REQUIRED) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Admin Configuration ──
# Comma-separated emails/usernames that get auto-promoted to admin on first login
ADMIN_EMAILS=your-admin@unilag.edu.ng
ADMIN_USERNAMES=your_admin_username

# ── Flutterwave Payment ──
# MODES:
#   'locked'   → Payments disabled (returns mock responses). Use until official account is ready.
#   'sandbox'  → Flutterwave test mode (no real money). Good for development.
#   'live'     → Production mode (REAL MONEY). Only use with official account.
FLUTTERWAVE_MODE=locked
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_key
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_hash

# ── Upstash Redis (for real-time features + rate limiting) ──
# Get credentials at https://upstash.com — free tier available
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Socket.io Authentication ──
# Secret key for signing Socket.io auth tokens (auto-generated on Render)
# Must be a strong random string in production
SOCKET_TOKEN_SECRET=your-strong-random-secret-here

# ── Push Notifications ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Uploadthing (Cloud Image Storage) ──
# Get your token at https://uploadthing.com — free tier available
# If not set, images fall back to base64 compression (works but less efficient)
UPLOADTHING_TOKEN=your-uploadthing-token

# ── App Config ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Security ──
# Secret key for protecting the /api/seed endpoint
SEED_SECRET_KEY=your-secret-seed-key
# Secret for cron endpoint verification
CRON_SECRET=your-cron-secret
